# ============================================
# 🗄️ MONGODB CONFIGURATION (REQUIRED!)
# ============================================
# Get this from MongoDB Atlas
# Atlas → Your Cluster → Connect → Drivers
# Copy the connection string and paste here
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/omniai?retryWrites=true&w=majority

# ============================================
# 🔐 JWT SECRETS (REQUIRED!)
# ============================================
# Generate random strings (32+ characters)
# Use: openssl rand -base64 32
JWT_SECRET=your_super_long_random_secret_key_here_32_chars_minimum
JWT_REFRESH_SECRET=your_refresh_super_long_random_secret_key_here_32_chars_minimum
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ============================================
# 🌍 APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ============================================
# 🤖 GROK / xAI CONFIGURATION
# ============================================
XAI_API_KEY=your_xai_key_here
XAI_MODEL=grok-4

# ============================================
# 📧 EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# Use a Gmail App Password here, not your normal Gmail password.
# Google no longer supports "less secure apps" for this flow.
EMAIL_USER=example@gmail.com
EMAIL_PASS=app_password_here

